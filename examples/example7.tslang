Deschodt Eric() -> int
    eric nom = "Mat\n\nhe\no" -> string
    eric age = 21 -> int
    eric i = 0 -> int
    eric n = 0 -> int

    peric("Bonjour {nom}, tu as {age} ans.")
    darius (nom[i] != '\0'):
        erif (nom[i] == '\n'):
            n += 1
        deschelse:
            peric("{nom[i]}"
        i += 1
    peric("Ton nom contient {i} caractères et {n} sauts de ligne.")
    deschodt 0

desnote print Bonjour Mathéo, tu as 21 ans.
